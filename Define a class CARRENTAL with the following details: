class CARRENTAL {
    int CarId;
    String CarType;
    float Rent;

    void GetCar(int id, String type) {
        CarId = id;
        CarType = type;
    }

    float GetRent() {
        if (CarType.equals("Small Car")) return 1000;
        if (CarType.equals("Van")) return 800;
        if (CarType.equals("SUV")) return 2500;
        return 0;
    }

    void ShowCar() {
        Rent = GetRent();
        System.out.println("ID: " + CarId + ", Type: " + CarType + ", Rent: " + Rent);
    }
}

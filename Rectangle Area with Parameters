class Rectangle {
    int length, breadth;
    Rectangle(int l, int b) { length = l; breadth = b; }
    int Area() { return length * breadth; }
}

public class Test {
    public static void main(String[] args) {
        System.out.println("Area 1: " + new Rectangle(4, 5).Area());
        System.out.println("Area 2: " + new Rectangle(5, 8).Area());
    }
}
